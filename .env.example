# Spark network: MAINNET or TESTNET
SPARK_NETWORK=TESTNET

# Resource server wallet mnemonic (receives payments)
SERVER_MNEMONIC=

# Client wallet mnemonic (sends payments)
CLIENT_MNEMONIC=

# Facilitator config
FACILITATOR_PORT=4020

# Resource server config
SERVER_PORT=4021
RESOURCE_PRICE_SATS=1000

# Facilitator URL (resource server calls this)
FACILITATOR_URL=http://localhost:4020
